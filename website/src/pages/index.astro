---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Floatify - Session Floaters for Claude Code and Codex">
  <!-- Skip to main content for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[#88c0d0] focus:text-[#2e3440] focus:rounded-lg">
    Skip to main content
  </a>

  <!-- Navigation -->
  <header>
    <nav id="navbar" aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-terminal-text" aria-label="Floatify home">
          Floatify
          <span class="sr-only"> - Session Floaters for Claude Code and Codex</span>
        </a>
      <a
        href="https://github.com/hieppp/floatify"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-terminal-surface border border-terminal-border hover:bg-terminal-border-hover transition-colors"
      >
        <svg class="w-5 h-5 text-terminal-text" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="text-sm text-terminal-text">Star</span>
      </a>
    </div>
  </nav>
  </header>

  <!-- Main Content -->
  <main id="main-content">

  <!-- Hero Section -->
  <section aria-labelledby="hero-heading" class="min-h-screen flex flex-col items-center justify-center px-6 pt-20">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h1 id="hero-heading" class="text-5xl md:text-6xl font-bold text-terminal-text mb-6 leading-tight">
        Floating Session HUDs<br/>for Developers
      </h1>
      <p class="text-xl text-terminal-text-secondary mb-8">
        Per-session floaters that stay visible without stealing focus
      </p>
      <p class="text-lg text-terminal-text-tertiary">
        A macOS menu bar app for Claude Code and Codex. It shows one persistent floater per live session with project labels, color-coded status, git file changes count, and activity timestamps.
      </p>
    </div>

    <!-- Terminal Window -->
    <div
      id="terminal"
      class="w-full max-w-2xl rounded-xl overflow-hidden cursor-pointer transition-all duration-200 hover:border-terminal-border-hover"
      style="background: #3b4252; border: 1px solid #4c566a;"
    >
      <!-- Terminal Header -->
      <div class="flex items-center gap-2 px-4 py-3" style="background: #2e3440;">
        <div class="w-3 h-3 rounded-full bg-terminal-dot"></div>
        <div class="w-3 h-3 rounded-full bg-terminal-dot"></div>
        <div class="w-3 h-3 rounded-full bg-terminal-dot"></div>
        <span class="ml-4 text-sm text-terminal-text-muted">zsh</span>
      </div>
      <!-- Terminal Body -->
      <div class="px-6 py-8 font-mono text-sm">
        <div class="flex items-center">
          <span class="text-terminal-text">$</span>
          <span id="typed-command" class="ml-2 text-terminal-text"></span>
          <span id="cursor" class="ml-1 w-2.5 h-5 bg-terminal-text" style="display: inline-block;"></span>
        </div>
        <div id="copied-feedback" class="mt-4 text-terminal-text-secondary text-sm opacity-0 transition-opacity duration-300">
          Copied!
        </div>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="mt-10 flex items-center justify-center gap-4">
      <a
        href="#installation"
        class="px-6 py-3 rounded-lg bg-[#88c0d0] text-[#2e3440] font-mono text-sm font-medium transition-colors hover:bg-[#81a1c1]"
      >
        Get Started
      </a>
      <a
        href="https://github.com/hieppp/floatify"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 rounded-lg border border-terminal-border text-terminal-text-secondary font-mono text-sm transition-colors hover:border-terminal-border-hover hover:text-terminal-text"
      >
        View on GitHub
      </a>
    </div>
  </section>

  <!-- Demo Section -->
  <section aria-labelledby="demo-heading" class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 id="demo-heading" class="text-xs text-terminal-text-tertiary tracking-wider uppercase text-center mb-10">See It In Action</h2>
      <div
        class="relative rounded-2xl overflow-hidden"
        style="border: 1px solid rgba(255,255,255,0.10); box-shadow: 0 0 0 1px rgba(255,255,255,0.04), 0 24px 56px rgba(0,0,0,0.55), 0 8px 20px rgba(0,0,0,0.35);"
      >
        <!-- macOS titlebar -->
        <div class="flex items-center gap-2 px-4 py-3" style="background: #2e3440; border-bottom: 1px solid rgba(255,255,255,0.07);">
          <div class="w-3 h-3 rounded-full" style="background: #bf616a;"></div>
          <div class="w-3 h-3 rounded-full" style="background: #ebcb8b;"></div>
          <div class="w-3 h-3 rounded-full" style="background: #a3be8c;"></div>
          <span class="ml-4 text-xs font-mono" style="color: #4c566a;">Floatify</span>
        </div>
        <img
          src="/demo.gif"
          alt="Floatify session floaters showing red running, yellow idle, and green complete states"
          class="w-full block"
          loading="lazy"
          style="display: block;"
        />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section aria-labelledby="features-heading" class="py-20 px-6 max-w-6xl mx-auto">
    <h2 id="features-heading" class="text-xs text-terminal-text-tertiary tracking-wider uppercase text-center mb-12">Features</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Feature 1: Sub-millisecond IPC -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Per-Session Floaters</h3>
        <p class="text-sm text-terminal-text-secondary">Each Claude Code or Codex session gets its own floater instead of one global status box.</p>
      </div>
      <!-- Feature 2: Zero Focus Stealing -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Zero Focus Stealing</h3>
        <p class="text-sm text-terminal-text-secondary">Non-activating NSPanel windows stay above apps without interrupting typing or mouse focus.</p>
      </div>
      <!-- Feature 3: Dead Zone Positioning -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Project-Aware Labels</h3>
        <p class="text-sm text-terminal-text-secondary">Each floater shows the current folder name, so multiple sessions stay easy to scan.</p>
      </div>
      <!-- Feature 4: Stackable Panels -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Drag, Close, Arrange</h3>
        <p class="text-sm text-terminal-text-secondary">Move floaters anywhere, close the ones you do not need, or restack them from the menu bar.</p>
      </div>
      <!-- Feature 5: FIFO Pipe IPC -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Color-First Status</h3>
        <p class="text-sm text-terminal-text-secondary">Red means running. Green means complete. Status stays readable without extra words.</p>
      </div>
      <!-- Feature 6: Developer-First -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Claude and Codex</h3>
        <p class="text-sm text-terminal-text-secondary">Claude uses hook-driven status. Codex uses live process activity, so both tools show up together.</p>
      </div>
      <!-- Feature 7: Configurable -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Sprite HUD UI</h3>
        <p class="text-sm text-terminal-text-secondary">Persistent floaters use animated sprite characters and a compact HUD layout built for glanceable status.</p>
      </div>
      <!-- Feature 8: File Changes & Activity -->
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-6 hover:-translate-y-1 hover:border-terminal-border-hover transition-all duration-200">
        <svg class="w-6 h-6 text-terminal-text-secondary mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">File Changes & Activity</h3>
        <p class="text-sm text-terminal-text-secondary">See git modified files count and time since last activity. Stay informed about what is happening in each session at a glance.</p>
      </div>
    </div>
  </section>

  <!-- Configuration Section -->
  <section id="configuration" aria-labelledby="config-heading" class="py-20 px-6 max-w-4xl mx-auto">
    <h2 id="config-heading" class="text-xs text-terminal-text-tertiary tracking-wider uppercase mb-8">Configuration</h2>
    <p class="text-terminal-text-secondary mb-6">Floatify uses <code class="px-2 py-1 bg-terminal-card rounded text-sm">positions.json</code> for per-position notification settings. Place your custom config at <code class="px-2 py-1 bg-terminal-card rounded text-sm">~/.floatify/positions.json</code>.</p>
    <div class="relative rounded-lg overflow-hidden border border-terminal-border bg-terminal-card">
      <div class="flex items-center justify-between px-4 py-2 border-b border-terminal-border" style="background: #2e3440;">
        <span class="text-xs text-terminal-text-muted font-mono">positions.json</span>
        <button onclick="copyCode(this)" class="text-xs text-terminal-text-secondary hover:text-terminal-text px-2 py-1 rounded bg-terminal-surface hover:bg-terminal-border-hover transition-colors">Copy</button>
      </div>
      <pre class="p-4 text-sm font-mono text-terminal-text overflow-x-auto"><code>{`{
  "bottomRight": {
    "margin": 20,
    "width": 320,
    "height": 80,
    "stackOffset": 6
  },
  "center": {
    "margin": 0,
    "width": 280,
    "height": 68,
    "stackOffset": 4
  }
}`}</code></pre>
    </div>
    <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-4">
        <p class="text-xs text-terminal-text-muted font-mono mb-1">margin</p>
        <p class="text-sm text-terminal-text">Screen edge distance (px)</p>
      </div>
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-4">
        <p class="text-xs text-terminal-text-muted font-mono mb-1">width</p>
        <p class="text-sm text-terminal-text">Panel width (px)</p>
      </div>
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-4">
        <p class="text-xs text-terminal-text-muted font-mono mb-1">height</p>
        <p class="text-sm text-terminal-text">Panel height (px)</p>
      </div>
      <div class="bg-terminal-card border border-terminal-border rounded-lg p-4">
        <p class="text-xs text-terminal-text-muted font-mono mb-1">stackOffset</p>
        <p class="text-sm text-terminal-text">Stack spacing (px)</p>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section aria-labelledby="how-it-works-heading" class="py-20 px-6 max-w-6xl mx-auto">
    <h2 id="how-it-works-heading" class="text-xs text-terminal-text-tertiary tracking-wider uppercase text-center mb-12">How It Works</h2>
    <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-8 md:gap-4">
      <!-- Step 1 -->
      <div class="flex-1 flex flex-col items-center text-center relative">
        <div class="w-12 h-12 rounded-full bg-terminal-surface text-terminal-text flex items-center justify-center text-xl font-bold mb-4 z-10">1</div>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Hook Trigger</h3>
        <p class="text-sm text-terminal-text-secondary">Claude hooks or session monitors detect live Claude Code and Codex sessions.</p>
        <!-- Arrow 1 (hidden on mobile, shown between steps on desktop) -->
        <div class="hidden md:block absolute top-6 right-0 translate-x-1/2 w-8 h-0.5 bg-terminal-border"></div>
      </div>
      <!-- Step 2 -->
      <div class="flex-1 flex flex-col items-center text-center relative">
        <div class="w-12 h-12 rounded-full bg-terminal-surface text-terminal-text flex items-center justify-center text-xl font-bold mb-4 z-10">2</div>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">CLI Command</h3>
        <p class="text-sm text-terminal-text-secondary">floatify sends status or notification payloads through the FIFO pipe.</p>
        <!-- Arrow 2 (hidden on mobile, shown between steps on desktop) -->
        <div class="hidden md:block absolute top-6 right-0 translate-x-1/2 w-8 h-0.5 bg-terminal-border"></div>
      </div>
      <!-- Step 3 -->
      <div class="flex-1 flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-full bg-terminal-surface text-terminal-text flex items-center justify-center text-xl font-bold mb-4 z-10">3</div>
        <h3 class="text-lg font-semibold text-terminal-text mb-2">Persistent Floater</h3>
        <p class="text-sm text-terminal-text-secondary">One HUD per session with project label, sprite, color status, file changes count, and activity timestamp.</p>
      </div>
    </div>
  </section>

  <!-- CLI Reference -->
  <section id="cli-reference" aria-labelledby="cli-heading" class="py-20 px-6 max-w-4xl mx-auto">
    <h2 id="cli-heading" class="text-xs text-terminal-text-tertiary tracking-wider uppercase mb-8">CLI Reference</h2>
    <div class="space-y-6">
      <div class="relative rounded-lg overflow-hidden border border-terminal-border bg-terminal-card">
        <div class="flex items-center justify-between px-4 py-2 border-b border-terminal-border" style="background: #2e3440;">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
          </div>
          <button onclick="copyCode(this)" class="text-xs text-terminal-text-secondary hover:text-terminal-text px-2 py-1 rounded bg-terminal-surface hover:bg-terminal-border-hover transition-colors">Copy</button>
        </div>
        <pre class="p-4 text-sm font-mono text-terminal-text overflow-x-auto"><code>floatify --message "Task complete!"</code></pre>
      </div>
      <div class="relative rounded-lg overflow-hidden border border-terminal-border bg-terminal-card">
        <div class="flex items-center justify-between px-4 py-2 border-b border-terminal-border" style="background: #2e3440;">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
          </div>
          <button onclick="copyCode(this)" class="text-xs text-terminal-text-secondary hover:text-terminal-text px-2 py-1 rounded bg-terminal-surface hover:bg-terminal-border-hover transition-colors">Copy</button>
        </div>
        <pre class="p-4 text-sm font-mono text-terminal-text overflow-x-auto"><code>floatify --message "Deploy done!" --position bottomRight</code></pre>
      </div>
      <div class="relative rounded-lg overflow-hidden border border-terminal-border bg-terminal-card">
        <div class="flex items-center justify-between px-4 py-2 border-b border-terminal-border" style="background: #2e3440;">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
          </div>
          <button onclick="copyCode(this)" class="text-xs text-terminal-text-secondary hover:text-terminal-text px-2 py-1 rounded bg-terminal-surface hover:bg-terminal-border-hover transition-colors">Copy</button>
        </div>
        <pre class="p-4 text-sm font-mono text-terminal-text overflow-x-auto"><code>floatify --message "Build failed" --position bottomLeft --duration 10</code></pre>
      </div>
      <div class="relative rounded-lg overflow-hidden border border-terminal-border bg-terminal-card">
        <div class="flex items-center justify-between px-4 py-2 border-b border-terminal-border" style="background: #2e3440;">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
            <span class="w-3 h-3 rounded-full bg-terminal-dot"></span>
          </div>
          <button onclick="copyCode(this)" class="text-xs text-terminal-text-secondary hover:text-terminal-text px-2 py-1 rounded bg-terminal-surface hover:bg-terminal-border-hover transition-colors">Copy</button>
        </div>
        <pre class="p-4 text-sm font-mono text-terminal-text overflow-x-auto"><code>floatify --status complete</code></pre>
      </div>
    </div>
  </section>

  <!-- Claude Code Integration -->
  <section id="claude-code-integration" aria-labelledby="claude-integration-heading" class="py-20 px-6 max-w-4xl mx-auto">
    <h2 id="claude-integration-heading" class="text-xs text-terminal-text-tertiary tracking-wider uppercase mb-8">Claude Code Integration</h2>
    <p class="text-terminal-text-secondary mb-6">Claude should send completion state only. Floatify discovers live Claude sessions itself, and Codex sessions are detected automatically.</p>
    <div class="relative rounded-lg overflow-hidden border border-terminal-border bg-terminal-card">
      <div class="flex items-center justify-between px-4 py-2 border-b border-terminal-border" style="background: #2e3440;">
        <span class="text-xs text-terminal-text-muted font-mono">settings.json</span>
        <button onclick="copyCode(this)" class="text-xs text-terminal-text-secondary hover:text-terminal-text px-2 py-1 rounded bg-terminal-surface hover:bg-terminal-border-hover transition-colors">Copy</button>
      </div>
        <pre class="p-4 text-sm font-mono text-terminal-text overflow-x-auto"><code>{`{
  "hooks": {
    "Stop": [{
      "hooks": [{
        "type": "command",
        "command": "floatify --status complete"
      }]
    }],
    "SessionEnd": [{
      "hooks": [{
        "type": "command",
        "command": "floatify --status complete"
      }]
    }]
  }
}`}</code></pre>
    </div>
    <p class="text-sm text-terminal-text-tertiary mt-4">Do not use <code class="px-2 py-1 bg-terminal-card rounded text-sm">UserPromptSubmit</code> for <code class="px-2 py-1 bg-terminal-card rounded text-sm">floatify --status running</code>.</p>
  </section>

