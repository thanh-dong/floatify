  <script>
    function copyCode(button: HTMLButtonElement) {
      const pre = button.closest('.relative')?.querySelector('code');
      if (pre) {
        navigator.clipboard.writeText(pre.textContent || '').then(() => {
          const original = button.textContent;
          button.textContent = 'Copied!';
          setTimeout(() => { button.textContent = original; }, 2000);
        });
      }
    }

    // Terminal typing animation
    const command = "$ git clone https://github.com/hieppp/floatify.git";
    const typedCommand = document.getElementById("typed-command");
    const cursor = document.getElementById("cursor");
    const terminal = document.getElementById("terminal");
    const copiedFeedback = document.getElementById("copied-feedback");

    let charIndex = 0;

    function typeCharacter() {
      if (charIndex < command.length) {
        typedCommand.textContent += command[charIndex];
        charIndex++;
        setTimeout(typeCharacter, 40 + Math.random() * 60);
      } else {
        terminal.classList.add("typing-complete");
      }
    }

    terminal?.addEventListener("click", () => {
      navigator.clipboard.writeText("git clone https://github.com/hieppp/floatify.git").then(() => {
        if (copiedFeedback) {
          copiedFeedback.style.opacity = "1";
          setTimeout(() => {
            copiedFeedback.style.opacity = "0";
          }, 1500);
        }
      });
    });

    setTimeout(typeCharacter, 500);

    // Navbar scroll behavior
    const navbar = document.getElementById("navbar");
    window.addEventListener("scroll", () => {
      const scrollY = window.scrollY;
      if (scrollY > 50) {
        navbar.style.background = "rgba(46, 52, 64, 0.95)";
        navbar.style.backdropFilter = "blur(10px)";
        navbar.style.borderBottom = "1px solid #4c566a";
      } else {
        navbar.style.background = "transparent";
        navbar.style.backdropFilter = "none";
        navbar.style.borderBottom = "none";
      }
    });

    // Demo notification animation
    const demoNotification = document.getElementById("demo-notification");
    const demoPositionLabel = document.getElementById("demo-position-label");
    const demoCornerLabel = document.getElementById("demo-corner-label");
    if (demoNotification) {
      const corners = [
        { name: "bottomLeft", bottom: "16px", right: "", top: "", left: "16px", baseTransform: "", slideFrom: "translateY(8px)" },
        { name: "bottomRight", bottom: "16px", right: "16px", top: "", left: "", baseTransform: "", slideFrom: "translateY(8px)" },
        { name: "topLeft", bottom: "", right: "", top: "16px", left: "16px", baseTransform: "", slideFrom: "translateY(-8px)" },
        { name: "topRight", bottom: "", right: "16px", top: "16px", left: "", baseTransform: "", slideFrom: "translateY(-8px)" },
        { name: "center", bottom: "", right: "", top: "", left: "50%", baseTransform: "translate(-50%, -50%)", slideFrom: "scale(0.9)" },
        { name: "menubar", bottom: "", right: "", top: "0px", left: "50%", baseTransform: "translateX(-50%)", slideFrom: "translateY(-100%)" },
        { name: "horizontal", bottom: "", right: "", top: "50%", left: "50%", baseTransform: "translate(-50%, -50%)", slideFrom: "translateX(100%)" },
        { name: "cursorFollow", bottom: "", right: "", top: "", left: "", baseTransform: "", slideFrom: "scale(0.8)" },
      ];
      let cornerIndex = 0;

      function showNotification() {
        const corner = corners[cornerIndex];
        // Clear all position props first
        ["top","bottom","left","right"].forEach(p => demoNotification.style.removeProperty(p));
        // Set new position
        if (corner.bottom) demoNotification.style.bottom = corner.bottom;
        if (corner.right) demoNotification.style.right = corner.right;
        if (corner.top) demoNotification.style.top = corner.top;
        if (corner.left) demoNotification.style.left = corner.left;
        // Animate in
        demoNotification.style.opacity = "1";
        demoNotification.style.transform = corner.baseTransform;
        if (demoPositionLabel) demoPositionLabel.textContent = corner.name;
        if (demoCornerLabel) demoCornerLabel.textContent = corner.name;
        // Animate out
        setTimeout(() => {
          demoNotification.style.opacity = "0";
          demoNotification.style.transform = corner.baseTransform + " " + corner.slideFrom;
        }, 2200);
        cornerIndex = (cornerIndex + 1) % corners.length;
      }

      let demoObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            showNotification();
            const interval = setInterval(() => showNotification(), 3500);
            demoObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      demoObserver.observe(demoNotification.closest("section"));
    }
  </script>
